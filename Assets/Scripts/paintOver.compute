// Each #kernel tells which function to compile; you can have many kernels
#pragma kernel CSMain

// Create a RenderTexture with enableRandomWrite flag and set it
// with cs.SetTexture
RWTexture2D<float4> Result;
Texture2D<float4> base;
vector brush;
float4 paint;
[numthreads(8,8,1)]
void CSMain (uint3 id : SV_DispatchThreadID)
{
    if(/*base[id.xy].x==paint.x && base[id.xy].y==paint.y && base[id.xy].z==paint.z*/distance((float3)base[id.xy],(float3)paint)<0.2f)
    {
        float dist = distance(id.xy,(float2)brush);
        if(50>dist)
        {
            Result[id.xy]=base[id.xy];
        }
    }
}
